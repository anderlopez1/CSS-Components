{
    "name": "untitledui-components",
    "version": "1.0.0",
    "description": "Production-ready React component library built on React Aria Components with Tailwind CSS",
    "license": "MIT",
    "author": "Ander Lopez <anderlopez1@gmail.com>",
    "homepage": "https://github.com/anderlopez1/CSS-Components",
    "repository": {
        "type": "git",
        "url": "https://github.com/anderlopez1/CSS-Components.git",
        "directory": "."
    },
    "keywords": [
        "react",
        "components",
        "ui-library",
        "tailwind",
        "react-aria",
        "typescript"
    ],
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "sideEffects": [
        "**/*.css"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "require": "./dist/index.js",
            "import": "./dist/index.mjs"
        },
        "./styles": "./src/styles/globals.css"
    },
    "files": [
        "dist",
        "src/styles"
    ],
    "scripts": {
        "dev": "next dev --turbopack",
        "build": "next build",
        "start": "next start",
        "build:lib": "npx tsc -p tsconfig.build.json && npx tsc-alias -p tsconfig.build.json && node scripts/build-esm.js",
        "prepublishOnly": "npm run build:lib",
        "prepare": "npm run build:lib"
    },
    "dependencies": {
        "@react-aria/utils": "^3.34.1",
        "@react-stately/utils": "^3.12.1",
        "@react-types/overlays": "^3.10.0",
        "@tailwindcss/postcss": "^4.2.2",
        "@tailwindcss/typography": "^0.5.19",
        "@untitledui/file-icons": "^0.0.9",
        "@untitledui/icons": "^0.0.22",
        "embla-carousel-react": "^8.6.0",
        "input-otp": "^1.4.2",
        "motion": "^12.38.0",
        "next": "16.2.0",
        "next-themes": "^0.4.6",
        "qr-code-styling": "^1.9.2",
        "react": "^19.2.4",
        "react-aria": "^3.47.0",
        "react-aria-components": "^1.16.0",
        "react-dom": "^19.2.4",
        "react-hotkeys-hook": "^5.2.4",
        "recharts": "^3.8.0",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.2",
        "tailwindcss-animate": "^1.0.7",
        "tailwindcss-react-aria-components": "^2.0.1"
    },
    "devDependencies": {
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "postcss": "^8.5.8",
        "postcss-loader": "^8.2.1",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "tsc-alias": "^1.9.1",
        "typescript": "^5.9.3"
    }
}
